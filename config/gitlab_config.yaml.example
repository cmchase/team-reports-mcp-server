# GitLab Configuration Example
# Copy this file to gitlab_config.yaml and customize for your team.
# Set GITLAB_TOKEN in .env. Do not commit gitlab_config.yaml (may contain PII/internal paths).

# Base URL for GitLab API (use for self-hosted instances)
base_url: "https://gitlab.example.com"

# List of projects to analyze (path with namespace, e.g. group/subgroup/project)
projects:
  - "your-group/your-project"

# Report settings
report_settings:
  max_results: 100
  include_private: true
  track_merge_requests: true
  track_commits: true
  track_issues: true
  timezone: "UTC"
  max_contributors_in_overview: 15
  max_recent_items_per_contributor: 10

# API settings (verify_ssl: false for self-hosted with self-signed certs)
api_settings:
  rate_limit_buffer: 100
  timeout: 30
  max_retries: 3
  retry_delay: 1
  verify_ssl: true

# Contributor filters
contributor_filters:
  exclude_bots: true
